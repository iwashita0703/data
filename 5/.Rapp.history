getwd()#
# setwd("自分のフォルダパス")#
#
# データ読み込み#
Body <- read.table("SampleData03_forR2.csv", header=TRUE, sep=",")#
#
# PDF出力#
pdf("figs_9_15.pdf")#
#
# ★ 使う2列（自由に変更OK）#
x <- Body[,6]#
y <- Body[,7]#
#
# ① パターン1#
plot(x, y,#
     pch=1, col="red",#
     main="Pattern 1")#
#
# ② パターン2#
plot(x, y,#
     pch=16, col="blue",#
     main="Pattern 2")#
#
# ③ パターン3（塗りつぶしあり）#
plot(x, y,#
     pch=21, col="green", bg="yellow",#
     main="Pattern 3")#
#
# 保存#
dev.off()
# 作業フォルダ確認#
getwd()#
# setwd("自分のフォルダパス")#
#
# データ読み込み#
Body <- read.table("SampleData03_forR2.csv", header=TRUE, sep=",")#
#
# PDF出力#
pdf("figs_9_16.pdf")#
#
# ★ 4つの列を選ぶ（自由）#
cols <- c(6,7,8,9)#
#
# ★ 性別で色分け（ここがポイント）#
pairs(Body[, cols],#
      pch=21,#
      bg=c("red","blue")[unclass(Body$Sex)],#
      main="Scatter Plot Matrix (Colored by Sex)")#
#
# 保存#
dev.off()
Body <- read.table("SampleData03_forR2.csv", header=TRUE, sep=",")#
#
# 念のためfactor化#
Body$Sex <- factor(Body$Sex)#
#
pdf("figs_9_16.pdf")#
#
pairs(Body[, c(6,7,8,9)],#
      pch=21,#
      bg=c("red","blue")[unclass(Body$Sex)],#
      main="Colored by Sex")#
#
dev.off()
# データ読み込み#
Body <- read.table("SampleData03_forR2.csv", header=TRUE, sep=",")#
#
# ★ ここだけ変えればOK（任意の4列）#
cols <- c(4,6,8,9)#
#
# PDF出力#
pdf("figs_9_13.pdf")#
#
# 散布図一覧#
plot(Body[, cols],#
     main=paste("Scatter Plot Matrix:", paste(cols, collapse=", ")))#
#
# 保存#
dev.off()
# データ読み込み#
Body <- read.table("SampleData03_forR2.csv", header=TRUE, sep=",")#
